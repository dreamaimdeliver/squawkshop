:true,"columns_mobile":"3","margin_spacing":"negative","margin_top":0}},"rich_text_fxBntk":{"type":"rich-text","blocks":{"heading_6n6BG7":{"type":"heading","settings":{"heading":"How to <em>choose<\/em> the right parrot cage?","heading_size":"large","heading_style":"default","heading_tag":"h2","highlight_option":"underline-hand","word_animation_color":"#fe0126"}},"text_wgxWBi":{"type":"text","settings":{"text":"<ul><li><strong>Go bigger when you can:<\/strong> Your bird should be able to fully stretch wings, climb, and move between perches comfortably.<br\/><\/li><li><strong>Bar spacing is critical:<\/strong> Too wide can be unsafe for smaller birds; too narrow can limit climbing for larger parrots.<br\/><\/li><li><strong>Match the cage to your routine:<\/strong> A roomy <strong>flight-style cage<\/strong> is great for active birds and longer out-of-cage transitions, while a taller “home base” cage works well for daily life and sleep.<br\/><br\/><\/li><\/ul><p><strong>Quick sizing tips (general guide)<\/strong><\/p><p><\/p><ul><li><strong>Parakeets \/ Cockatiels \/ Small Conures:<\/strong> smaller bar spacing, roomy interior<br\/><\/li><li><strong>African Greys \/ Amazons \/ Medium Parrots:<\/strong> medium spacing with strong bar gauge<br\/><\/li><li><strong>Macaws \/ Cockatoos:<\/strong> heavy-duty construction, larger spacing, maximum stability<br\/><\/li><\/ul><p>Some of our options are available as <strong>bundles<\/strong>, making it easier to start with a solid setup from day one. If you’re unsure what fits your bird best, start with the size you think you need, then go one size up. Your bird will thank you.<\/p>"}}},"block_order":["heading_6n6BG7","text_wgxWBi"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","full_width":true,"color_scheme":"","padding_top":12,"padding_bottom":0,"ignore_spacing":false,"margin_spacing":"negative","margin_top":0,"mobile_content_alignment":"left"}},"quick_