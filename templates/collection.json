{"sections":{"banner":{"type":"main-collection-banner","settings":{"show_collection_description":false,"show_breadcrumbs":true,"collection_style":"style-three","desktop_content_alignment":"left","image_height":"small","image_overlay_opacity":20,"color_scheme":"option-3","image":"shopify:\/\/shop_images\/IMG_2226.jpg","image_for_all":false,"fallback_heading":"Parrot Cages","padding_top":6,"padding_bottom":0}},"rich_text_N7HFVQ":{"type":"rich-text","blocks":{"text_xNjDfK":{"type":"text","settings":{"text":"<p>A <strong>parrot cage<\/strong> isn’t just a place your bird stays — it’s their <strong>home base<\/strong> for sleeping, eating, playing, and feeling secure. At Squawk Shop, we focus on cages that are sturdy, bird-safe, and sized for real life with parrots — from cockatiels and conures to African Greys, Amazons, macaws, and cockatoos.<\/p><p><\/p><p><strong>Shop parrot cages below<\/strong> and build a setup your feathered friend will actually love living in.<\/p>"}}},"block_order":["text_xNjDfK"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"option-1","padding_top":12,"padding_bottom":0,"ignore_spacing":false,"margin_spacing":"negative","margin_top":0,"mobile_content_alignment":"left"}},"subcollections":{"type":"subcollections","settings":{"title":"","heading_size":"medium","heading_tag":"h2","caption":"","text_style":"caption-with-letter-spacing","text_size":"large","subcollection_list_style":"collection-list-three","image_ratio":"square","collections_to_show":10,"columns_desktop":3,"enable_desktop_slider":false,"color_scheme":"option-1","color_scheme_1":"option-2","padding_top":24,"padding_bottom":0,"ignore_spacing":true,"margin_spacing":"negative","margin_top":0,"columns_mobile":"2","swipe_on_mobile":true,"disable_arrow_mobile":true}},"product-grid":{"type":"main-collection-product-grid","blocks":{"promo_row":{"type":"promo_row","settings":{"promo_row":"7"