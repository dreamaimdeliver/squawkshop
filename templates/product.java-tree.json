        "custom_liquid_xbD68N": {
          "type": "custom_liquid",
          "settings": {
            "column": "left",
            "custom_liquid": "<div class=\"tree-picker\">\n  <div class=\"tree-picker__title\">Pick your exact tree</div>\n\n  <div class=\"tree-picker__grid\">\n    {% for v in product.variants %}\n      {% assign img = v.featured_image %}\n      {% if img and v.available %}\n        <a class=\"tree-picker__item {% if v.id == product.selected_or_first_available_variant.id %}is-active{% endif %}\"\n           href=\"{{ product.url }}?variant={{ v.id }}\">\n          <img\n            src=\"{{ img | image_url: width: 220 }}\"\n            alt=\"Squawk Shop Java Tree {{ v.title }}\"\n            loading=\"lazy\"\n          />\n          <div class=\"tree-picker__label\">Java Tree {{ v.title }}</div>\n        </a>\n      {% endif %}\n    {% endfor %}\n  </div>\n\n  <div class=\"tree-picker__note\">\n    You will receive the exact tree you select. Branch layout varies by Tree ID.\n  </div>\n</div>\n\n<style>\n  .tree-picker { margin-top: 14px; }\n  .tree-picker__title { font-weight: 700; margin-bottom: 10px; }\n  .tree-picker__grid {\n    display: grid;\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n    gap: 10px;\n  }\n  @media (min-width: 750px){\n    .tree-picker__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }\n  }\n  .tree-picker__item {\n    border: 1px solid rgba(0,0,0,.12);\n    border-radius: 10px;\n    padding: 8px;\n    text-decoration: none;\n    display: block;\n    background: #fff;\n  }\n  .tree-picker__item.is-active { outline: 2px solid #fe0126; }\n  .tree-picker__item img { width: 100%; height: auto; display: block; border-radius: 8px; }\n  .tree-picker__label { margin-top: 6px; font-size: 12px; color: #18252e; font-weight: 600; text-align: center; }\n  .tree-picker__note { margin-top: 10px; font-size: 12px; opacity: .85; }\n</style>",
            "hide_quick_view": false
          }
        },
