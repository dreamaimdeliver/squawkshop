        "custom_liquid_xbD68N": {
          "type": "custom_liquid",
          "settings": {
            "column": "left",
            "custom_liquid": "<div class=\"tree-picker\" data-tree-picker>\n  <div class=\"tree-picker__title\">Pick your exact tree</div>\n\n  {% assign selected_tree = product.selected_or_first_available_variant %}\n  {% assign selected_tree_image = selected_tree.featured_image %}\n\n  <div class=\"tree-picker__selected\">\n    {% if selected_tree_image %}\n      <img\n        data-tree-picker-image\n        src=\"{{ selected_tree_image | image_url: width: 520 }}\"\n        alt=\"Squawk Shop Java Tree {{ selected_tree.title }}\"\n        loading=\"lazy\"\n        width=\"520\"\n        height=\"520\"\n      />\n    {% endif %}\n    <div class=\"tree-picker__selected-copy\">\n      <div class=\"tree-picker__selected-label\">Selected Tree ID</div>\n      <div class=\"tree-picker__selected-title\" data-tree-picker-title>Java Tree {{ selected_tree.title }}</div>\n      <p>Use the Tree ID buttons below. Only the selected tree photo loads here.</p>\n    </div>\n  </div>\n\n  <div class=\"tree-picker__note\">\n    You will receive the exact tree you select. Branch layout varies by Tree ID.\n  </div>\n\n  <div class=\"tree-picker__dock\" data-tree-picker-dock hidden>\n    <img data-tree-picker-dock-image alt=\"\" width=\"160\" height=\"160\" />\n    <div class=\"tree-picker__dock-copy\">\n      <div class=\"tree-picker__selected-label\">Selected Tree ID</div>\n      <div class=\"tree-picker__dock-title\" data-tree-picker-dock-title></div>\n    </div>\n    <button class=\"tree-picker__dock-close\" type=\"button\" data-tree-picker-close aria-label=\"Close tree preview\">&times;</button>\n  </div>\n\n  <script type=\"application/json\" data-tree-picker-data>\n    {\n      {% for v in product.variants %}\n        {{ v.title | json }}: {\n          \"title\": {{ v.title | json }},\n          \"image\": {% if v.featured_image %}{{ v.featured_image | image_url: width: 520 | json }}{% else %}null{% endif %}\n        }{% unless forloop.last %},{% endunless %}\n      {% endfor %}\n    }\n  </script>\n</div>\n\n<script>\n  (() => {\n    const picker = document.currentScript.previousElementSibling;\n    if (!picker || picker.dataset.treePickerReady === 'true') return;\n    picker.dataset.treePickerReady = 'true';\n\n    const dataEl = picker.querySelector('[data-tree-picker-data]');\n    const imageEl = picker.querySelector('[data-tree-picker-image]');\n    const titleEl = picker.querySelector('[data-tree-picker-title]');\n    const dockEl = picker.querySelector('[data-tree-picker-dock]');\n    if (dockEl && dockEl.parentElement !== document.body) {\n      document.body.appendChild(dockEl);\n    }\n    const dockImageEl = dockEl?.querySelector('[data-tree-picker-dock-image]');\n    const dockTitleEl = dockEl?.querySelector('[data-tree-picker-dock-title]');\n    const closeEl = dockEl?.querySelector('[data-tree-picker-close]');\n    if (!dataEl || !imageEl || !titleEl || !dockEl || !dockImageEl || !dockTitleEl) return;\n\n    let trees = {};\n    try {\n      trees = JSON.parse(dataEl.textContent);\n    } catch (error) {\n      return;\n    }\n\n    const updateImage = (img, src, alt) => {\n      img.alt = alt;\n      if (img.getAttribute('src') !== src) {\n        img.setAttribute('src', src);\n      }\n    };\n\n    const showTree = (value, revealDock = false) => {\n      const tree = trees[value];\n      if (!tree || !tree.image) return;\n\n      const title = 'Java Tree ' + tree.title;\n      const alt = 'Squawk Shop ' + title;\n      titleEl.textContent = title;\n      updateImage(imageEl, tree.image, alt);\n      dockTitleEl.textContent = title;\n      updateImage(dockImageEl, tree.image, alt);\n      if (revealDock) dockEl.hidden = false;\n    };\n\n    document.addEventListener('click', (event) => {\n      const label = event.target.closest('label.variant-buttons');\n      if (!label) return;\n\n      const input = label.htmlFor ? document.getElementById(label.htmlFor) : null;\n      if (!input || !input.name || input.name.indexOf('options[') !== 0) return;\n      showTree(input.value, true);\n    });\n\n    document.addEventListener('change', (event) => {\n      const input = event.target;\n      if (!input || input.type !== 'radio' || !input.name || input.name.indexOf('options[') !== 0) return;\n      showTree(input.value, true);\n    });\n\n    closeEl?.addEventListener('click', () => {\n      dockEl.hidden = true;\n    });\n  })();\n</script>\n\n<style>\n  .tree-picker { margin-top: 14px; }\n  .tree-picker__title { font-weight: 700; margin-bottom: 10px; }\n  .tree-picker__selected {\n    border: 1px solid rgba(0,0,0,.12);\n    border-radius: 10px;\n    padding: 10px;\n    background: #fff;\n    display: grid;\n    grid-template-columns: minmax(96px, 38%) 1fr;\n    gap: 12px;\n    align-items: center;\n  }\n  .tree-picker__selected img,\n  .tree-picker__dock img {\n    width: 100%;\n    height: auto;\n    display: block;\n    border-radius: 8px;\n  }\n  .tree-picker__selected-label {\n    font-size: 11px;\n    letter-spacing: .04em;\n    text-transform: uppercase;\n    opacity: .7;\n    margin-bottom: 3px;\n  }\n  .tree-picker__selected-title,\n  .tree-picker__dock-title {\n    color: #18252e;\n    font-size: 15px;\n    font-weight: 700;\n    line-height: 1.25;\n  }\n  .tree-picker__selected-copy p {\n    margin: 6px 0 0;\n    font-size: 12px;\n    line-height: 1.4;\n    opacity: .85;\n  }\n  .tree-picker__note { margin-top: 10px; font-size: 12px; opacity: .85; }\n  .tree-picker__dock[hidden] { display: none; }\n  .tree-picker__dock {\n    position: fixed;\n    left: 12px;\n    right: 12px;\n    bottom: 92px;\n    z-index: 2147483000;\n    display: grid;\n    grid-template-columns: 72px 1fr 32px;\n    gap: 10px;\n    align-items: center;\n    padding: 10px;\n    background: #fff;\n    border: 1px solid rgba(0,0,0,.12);\n    border-radius: 10px;\n    box-shadow: 0 10px 28px rgba(0,0,0,.18);\n  }\n  .tree-picker__dock-close {\n    width: 32px;\n    height: 32px;\n    border: 0;\n    border-radius: 50%;\n    background: #f3f5f7;\n    color: #18252e;\n    font-size: 23px;\n    line-height: 1;\n    cursor: pointer;\n  }\n  @media (min-width: 750px) {\n    .tree-picker__dock { display: none; }\n  }\n</style>",
            "hide_quick_view": false
          }
        },
