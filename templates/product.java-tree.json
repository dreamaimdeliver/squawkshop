        "tabs": {
          "type": "tabs",
          "settings": {
            "column": "left",
            "heading_1": "Returns & Exchanges",
            "row_content_1": "<p><em><strong>Easy returns and hassle-free exchanges.</strong></em> If you're not completely satisfied, you can return or exchange your items within 30 days. For hygiene and safety, items must be unused unless there is a defect or issue with your order. We want you and your bird to be truly happy with every purchase.</p>",
            "heading_2": "Delivery Info",
            "row_content_2": "<p><em><strong>Getting your parrots goodies to you, fast.</strong></em><br/>We partner with trusted carriers to make sure your orders reach you quickly and safely, no matter where you are.</p>",
            "heading_3": "Help & Support",
            "row_content_3": "<p><em><strong>Always here to assist you.</strong></em><br/>Questions about our products or your order? Our friendly support team is ready to help anytime you need.</p>",
            "centered_tabs": false,
            "remove_border_tabs": false,
            "margin_top": 0,
            "hide_quick_view": false
          }
